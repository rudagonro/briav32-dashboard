<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>BRIAV32 · Seguimiento Contractual</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1a3a5c;--navy2:#2e5f8a;--navy3:#e8f0f8;
  --red:#c0392b;--orange:#e67e22;--yellow:#f1c40f;--green:#27ae60;
  --bg:#f0f4f8;--white:#ffffff;--border:#c8d6e5;--border2:#a8bed4;
  --tx:#1a1a2e;--mu:#5a6a7a;--mu2:#8a9aaa;
  --shadow:0 2px 8px rgba(26,58,92,.12);--shadow2:0 4px 16px rgba(26,58,92,.15);
}
html,body{height:100%;overflow:hidden;font-family:'Roboto',sans-serif;background:var(--bg);color:var(--tx);font-size:13px}
.shell{display:flex;flex-direction:column;height:100vh}

/* TOP */
.top{flex-shrink:0;background:var(--navy);padding:.5rem 1.2rem;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:3px solid var(--yellow)}
.top-left{display:flex;align-items:center;gap:.75rem}
.top-icon{width:32px;height:32px;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.3);
  border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1rem}
.top-title{font-size:.95rem;font-weight:700;color:#fff;letter-spacing:.02em}
.top-sub{font-size:.62rem;color:rgba(255,255,255,.7);margin-top:.1rem}
.top-right{display:flex;align-items:center;gap:.5rem}
.top-tag{font-size:.62rem;color:rgba(255,255,255,.85);background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.25);padding:.2rem .65rem;border-radius:3px}

/* FILTERS */
.filters{flex-shrink:0;background:var(--white);border-bottom:2px solid var(--border);
  padding:.4rem 1.2rem;display:flex;align-items:center;gap:.6rem;overflow-x:auto}
.fl{font-size:.6rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  color:var(--navy);white-space:nowrap}
select,input{background:#fff;border:1.5px solid var(--border2);color:var(--tx);
  font-family:'Roboto',sans-serif;font-size:.72rem;padding:.3rem .6rem;
  border-radius:3px;outline:none;cursor:pointer;transition:border-color .15s}
select:focus,input:focus{border-color:var(--navy)}
input{width:180px}input::placeholder{color:var(--mu2)}
.fsep{width:1px;height:20px;background:var(--border);flex-shrink:0}
.btn{font-family:'Roboto',sans-serif;font-size:.7rem;font-weight:500;padding:.32rem .75rem;
  border-radius:3px;border:none;cursor:pointer;transition:all .15s;white-space:nowrap}
.btn-navy{background:var(--navy);color:#fff}.btn-navy:hover{background:var(--navy2)}
.btn-out{background:#fff;color:var(--navy);border:1.5px solid var(--navy2)}.btn-out:hover{background:var(--navy3)}

/* BODY */
.body{flex:1;display:flex;flex-direction:column;overflow:hidden;padding:.6rem 1rem;gap:.5rem}

/* KPI ROW */
.kpi-row{flex-shrink:0;display:grid;grid-template-columns:repeat(6,1fr);gap:.5rem}
.kpi{background:var(--white);border:1.5px solid var(--border);border-radius:4px;
  padding:.5rem .75rem;position:relative;overflow:hidden;box-shadow:var(--shadow)}
.kpi::after{content:'';position:absolute;top:0;left:0;bottom:0;width:4px;border-radius:4px 0 0 4px}
.kpi.k-navy::after{background:var(--navy)}
.kpi.k-blue::after{background:var(--navy2)}
.kpi.k-green::after{background:var(--green)}
.kpi.k-red::after{background:var(--red)}
.kpi.k-orange::after{background:var(--orange)}
.kpi.k-yellow::after{background:#d4a017}
.kpi-lbl{font-size:.56rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  color:var(--mu);margin-bottom:.25rem;padding-left:.3rem}
.kpi-val{font-family:'Roboto',sans-serif;font-size:.95rem;font-weight:700;
  color:var(--navy);padding-left:.3rem;line-height:1}
.kpi-sub{font-size:.58rem;color:var(--mu2);margin-top:.18rem;padding-left:.3rem}

/* MIDDLE ROW: charts */
.mid-row{flex-shrink:0;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:.5rem;height:175px}
.card{background:var(--white);border:1.5px solid var(--border);border-radius:4px;
  padding:.5rem .75rem;box-shadow:var(--shadow);display:flex;flex-direction:column;overflow:hidden}
.card-hdr{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:.3rem;flex-shrink:0}
.card-title{font-size:.62rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--navy)}
.card-count{font-size:.85rem;font-weight:700;color:var(--navy2)}
.cw{position:relative;flex:1;min-height:0}

/* STATUS BARS (like Risk Assessment Status) */
.status-section{display:flex;flex-direction:column;gap:.4rem;padding-top:.1rem}
.status-row{display:flex;align-items:center;gap:.4rem}
.status-lbl{font-size:.62rem;color:var(--mu);width:75px;flex-shrink:0;font-weight:500}
.status-bar{flex:1;height:18px;display:flex;border-radius:2px;overflow:hidden;border:1px solid var(--border)}
.sb-seg{display:flex;align-items:center;justify-content:center;font-size:.55rem;font-weight:700;color:#fff}
.sb-red{background:var(--red)}.sb-orange{background:var(--orange)}
.sb-green{background:var(--green)}.sb-yellow{background:#d4a017}

/* ACTION TABLE */
.action-table{width:100%;border-collapse:collapse;margin-top:.3rem}
.action-table th{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;
  color:var(--mu);border-bottom:1.5px solid var(--border);padding:.25rem .4rem;text-align:center}
.action-table td{font-size:.75rem;font-weight:500;padding:.3rem .4rem;text-align:center;
  border-bottom:1px solid var(--border)}
.action-table td:first-child{text-align:left;font-size:.68rem;color:var(--tx)}
.num-red{color:var(--red);font-weight:700}
.num-blue{color:var(--navy2);font-weight:700}

/* TABLE SECTION */
.table-section{flex:1;display:flex;flex-direction:column;min-height:0;
  background:var(--white);border:1.5px solid var(--border);border-radius:4px;
  box-shadow:var(--shadow);overflow:hidden}
.tbl-head{flex-shrink:0;background:var(--navy);padding:.35rem .8rem;
  display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-wrap:wrap}
.tbl-title{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#fff}
.tbl-meta{font-size:.6rem;color:rgba(255,255,255,.7)}
.tabs{display:flex;gap:.3rem}
.tab{font-size:.62rem;font-weight:500;padding:.22rem .65rem;border:1px solid rgba(255,255,255,.3);
  background:transparent;color:rgba(255,255,255,.75);cursor:pointer;border-radius:2px;transition:all .15s}
.tab.act{background:#fff;color:var(--navy);font-weight:700}

/* TABLE SCROLL */
.tbl-wrap{flex:1;overflow:auto;position:relative}
.scroll-hint{position:absolute;top:50%;transform:translateY(-50%);z-index:10;
  width:24px;height:50px;display:flex;align-items:center;justify-content:center;
  color:var(--navy2);font-size:1rem;font-weight:700;pointer-events:none;opacity:0;transition:opacity .3s}
.scroll-hint.left{left:0;background:linear-gradient(to right,rgba(255,255,255,.97),transparent)}
.scroll-hint.right{right:0;background:linear-gradient(to left,rgba(255,255,255,.97),transparent)}
.scroll-hint.visible{opacity:1}
.scroll-back{display:none;position:sticky;bottom:.5rem;float:right;margin-right:.5rem;z-index:20;
  background:var(--navy);color:#fff;font-size:.62rem;font-weight:600;
  padding:.3rem .75rem;border-radius:3px;cursor:pointer;border:none}
.scroll-back.show{display:inline-flex;align-items:center;gap:.3rem}

table{width:max-content;border-collapse:collapse;font-size:.68rem}
thead{position:sticky;top:0;z-index:5;background:var(--navy3)}
thead th{padding:.4rem .7rem;text-align:left;font-size:.56rem;font-weight:700;
  letter-spacing:.07em;text-transform:uppercase;color:var(--navy);
  border-bottom:2px solid var(--navy2);border-right:1px solid var(--border);
  white-space:nowrap;cursor:pointer;user-select:none}
thead th:hover{background:#d8e8f5;color:var(--navy)}
thead th.sa::after{content:' ↑';color:var(--navy2)}
thead th.sd::after{content:' ↓';color:var(--navy2)}
thead th:nth-child(1){position:sticky;left:0;z-index:6;background:var(--navy3)}
thead th:nth-child(2){position:sticky;left:80px;z-index:6;background:var(--navy3)}
thead th:nth-child(3){position:sticky;left:126px;z-index:6;background:var(--navy3)}
tbody tr{border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s}
tbody tr:nth-child(even){background:#fafcff}
tbody tr:hover{background:#e8f0f8}
tbody td{padding:.38rem .7rem;color:var(--tx);white-space:nowrap;
  border-right:1px solid var(--border);overflow:hidden;text-overflow:ellipsis}
tbody td:nth-child(1){position:sticky;left:0;z-index:2;background:#fff}
tbody td:nth-child(2){position:sticky;left:80px;z-index:2;background:#fff}
tbody td:nth-child(3){position:sticky;left:126px;z-index:2;background:#fff}
tbody tr:nth-child(even) td:nth-child(1),
tbody tr:nth-child(even) td:nth-child(2),
tbody tr:nth-child(even) td:nth-child(3){background:#fafcff}
tbody tr:hover td:nth-child(1),
tbody tr:hover td:nth-child(2),
tbody tr:hover td:nth-child(3){background:#e8f0f8}
.mono{font-family:'Roboto Mono',monospace;font-size:.63rem}
.tr{text-align:right}
.tdim{color:var(--mu)}

/* BADGES */
.badge{display:inline-flex;align-items:center;font-size:.58rem;font-weight:700;
  padding:.18rem .5rem;border-radius:2px;white-space:nowrap;letter-spacing:.04em}
.b-cxp{background:#dbeeff;color:#1a5fa8;border:1px solid #a8ccee}
.b-res{background:#fff3e0;color:#b45a00;border:1px solid #f0c080}
.b-liq{background:#e8f5e9;color:#1b7a35;border:1px solid #90c89a}

/* MODAL */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;
  align-items:center;justify-content:center;padding:1rem}
.ov.open{display:flex}
.modal{background:#fff;border:2px solid var(--navy);border-radius:4px;
  width:100%;max-width:680px;max-height:85vh;display:flex;flex-direction:column;
  box-shadow:0 8px 32px rgba(0,0,0,.2)}
.mh{flex-shrink:0;padding:.75rem 1rem;background:var(--navy);
  display:flex;align-items:flex-start;justify-content:space-between;gap:.75rem}
.mt{font-size:.78rem;font-weight:700;color:#fff;word-break:break-word}
.mc{background:none;border:none;color:rgba(255,255,255,.7);font-size:1.1rem;cursor:pointer;line-height:1;flex-shrink:0}
.mc:hover{color:#fff}
.mb{flex:1;overflow-y:auto;padding:1rem}
.dg{display:grid;grid-template-columns:1fr 1fr;gap:.65rem}
.di label{font-size:.56rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  color:var(--navy);display:block;margin-bottom:.2rem;border-bottom:1px solid var(--border);padding-bottom:.15rem}
.di .dv{font-size:.75rem;color:var(--tx);word-break:break-word;line-height:1.5;margin-top:.2rem}
.di.full{grid-column:1/-1}
.dsep{grid-column:1/-1;height:2px;background:var(--navy3);margin:.25rem 0}
.pb{height:8px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:.4rem;border:1px solid var(--border2)}
.pf{height:100%;background:var(--navy2)}

/* scrollbar */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#f0f4f8}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:var(--navy2)}
</style>
</head>
<body>
<div class="shell">

<!-- TOP -->
<div class="top">
  <div class="top-left">
    <img src="data:image/png;base64," style="width:42px;height:42px;border-radius:50%;border:2px solid rgba(255,255,255,.4);object-fit:cover;flex-shrink:0"/>
    <div>
      <div class="top-title">BRIAV32 · Panel de Seguimiento Contractual</div>
      <div class="top-sub">CXP · Reservas · Liquidaciones — CENACAVIACIÓN</div>
    </div>
  </div>
  <div class="top-right">
    <span class="top-tag">📅 Corte: 17 Mar 2026</span>
    <span class="top-tag" id="cntTag">150 registros</span>
  </div>
</div>

<!-- FILTERS -->
<div class="filters">
  <span class="fl">Vigencia</span>
  <select id="fV" onchange="go()"><option value="">Todas</option></select>
  <div class="fsep"></div>
  <span class="fl">Unidad</span>
  <select id="fU" onchange="go()"><option value="">Todas</option></select>
  <div class="fsep"></div>
  <span class="fl">Tipo</span>
  <select id="fT" onchange="go()"><option value="">Todos</option></select>
  <div class="fsep"></div>
  <span class="fl">Buscar</span>
  <input id="fQ" placeholder="Contrato, objeto, empresa, supervisor…" oninput="go()"/>
  <div class="fsep"></div>
  <button class="btn btn-out" onclick="reset()">✕ Limpiar</button>
  <button class="btn btn-navy" onclick="csv()">⬇ Exportar CSV</button>
</div>

<!-- BODY -->
<div class="body">

  <!-- KPIs -->
  <div class="kpi-row">
    <div class="kpi k-navy">
      <div class="kpi-lbl">Valor Total Contratos</div>
      <div class="kpi-val" id="kVC">—</div>
      <div class="kpi-sub">COP</div>
    </div>
    <div class="kpi k-blue">
      <div class="kpi-lbl">Cuentas por Pagar</div>
      <div class="kpi-val" id="kCXP">—</div>
      <div class="kpi-sub" id="kCXPn">— contratos</div>
    </div>
    <div class="kpi k-orange">
      <div class="kpi-lbl">Reservas</div>
      <div class="kpi-val" id="kRES">—</div>
      <div class="kpi-sub" id="kRESn">— contratos</div>
    </div>
    <div class="kpi k-green">
      <div class="kpi-lbl">Liquidaciones</div>
      <div class="kpi-val" id="kLIQ">—</div>
      <div class="kpi-sub" id="kLIQn">— en proceso</div>
    </div>
    <div class="kpi k-yellow">
      <div class="kpi-lbl">Total Registros</div>
      <div class="kpi-val" id="kREG">—</div>
      <div class="kpi-sub">en selección</div>
    </div>
    <div class="kpi k-red">
      <div class="kpi-lbl">Con Prórroga</div>
      <div class="kpi-val" id="kPRO">—</div>
      <div class="kpi-sub">contratos prorrogados</div>
    </div>
  </div>

  <!-- CHARTS ROW -->
  <div class="mid-row">

    <!-- Bar chart -->
    <div class="card">
      <div class="card-hdr">
        <span class="card-title">Valor Contrato por Unidad</span>
        <span class="card-count" id="cBtotal"></span>
      </div>
      <div class="cw"><canvas id="cBar"></canvas></div>
    </div>

    <!-- Tipo donut -->
    <div class="card">
      <div class="card-hdr">
        <span class="card-title">Por Tipo</span>
        <span class="card-count" id="cTtotal"></span>
      </div>
      <div class="cw"><canvas id="cTipo"></canvas></div>
    </div>

    <!-- Status bars -->
    <div class="card">
      <div class="card-hdr">
        <span class="card-title">Distribución por Vigencia</span>
      </div>
      <div class="status-section" id="vigStatus"></div>
    </div>

    <!-- Actions table -->
    <div class="card">
      <div class="card-hdr">
        <span class="card-title">Resumen por Unidad</span>
      </div>
      <div style="overflow-y:auto;flex:1">
        <table class="action-table" id="unitTable"></table>
      </div>
    </div>

  </div>

  <!-- TABLE -->
  <div class="table-section">
    <div class="tbl-head">
      <span class="tbl-title">Detalle de Contratos — 20 Columnas</span>
      <div class="tabs">
        <button class="tab act" onclick="setTab('all',this)">Todos</button>
        <button class="tab" onclick="setTab('CXP',this)">CXP</button>
        <button class="tab" onclick="setTab('Reservas',this)">Reservas</button>
        <button class="tab" onclick="setTab('Liquidaciones',this)">Liquidaciones</button>
      </div>
      <span class="tbl-meta" id="rowCnt">—</span>
    </div>
    <div class="tbl-wrap" id="tw">
      <div class="scroll-hint left" id="shL">‹</div>
      <div class="scroll-hint right" id="shR">›</div>
      <table>
        <thead><tr>
          <th onclick="srt('tipo')" style="min-width:80px">Tipo</th>
          <th onclick="srt('vigencia')" style="min-width:46px">Vig.</th>
          <th onclick="srt('unidad')" style="min-width:76px">Unidad</th>
          <th onclick="srt('contrato')" style="min-width:200px">Contrato</th>
          <th onclick="srt('supervisor')" style="min-width:190px">Supervisor</th>
          <th onclick="srt('nuevo_supervisor')" style="min-width:180px">Nuevo Supervisor</th>
          <th onclick="srt('objeto')" style="min-width:290px">Objeto</th>
          <th onclick="srt('plazo_ejecucion')" style="min-width:95px">Plazo Ejec.</th>
          <th onclick="srt('valor_contrato')" class="tr" style="min-width:155px">Valor Contrato</th>
          <th onclick="srt('valor_cxp')" class="tr" style="min-width:140px">Valor CXP</th>
          <th onclick="srt('valor_reserva')" class="tr" style="min-width:140px">Valor Reserva</th>
          <th onclick="srt('valor_ejecutado')" class="tr" style="min-width:130px">Ejecutado</th>
          <th onclick="srt('valor_pendiente')" class="tr" style="min-width:120px">Pendiente</th>
          <th onclick="srt('porcentaje_ejecucion')" class="tr" style="min-width:75px">% Ejec.</th>
          <th onclick="srt('fecha_prorroga')" style="min-width:95px">F. Prórroga</th>
          <th onclick="srt('empresa')" style="min-width:170px">Empresa</th>
          <th onclick="srt('ultima_actuacion')" style="min-width:270px">Última Actuación</th>
          <th onclick="srt('cantidad')" class="tr" style="min-width:55px">Cant.</th>
          <th onclick="srt('fecha_corte')" style="min-width:88px">F. Corte</th>
          <th onclick="srt('observaciones')" style="min-width:210px">Observaciones</th>
        </tr></thead>
        <tbody id="tb"></tbody>
      </table>
      <button class="scroll-back" id="sbBtn" onclick="tw.scrollTo({left:0,behavior:'smooth'})">⟵ Inicio</button>
    </div>
  </div>
</div>
</div>

<!-- MODAL -->
<div class="ov" id="ov" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal">
    <div class="mh">
      <div class="mt" id="mT">—</div>
      <button class="mc" onclick="document.getElementById('ov').classList.remove('open')">✕</button>
    </div>
    <div class="mb" id="mB"></div>
  </div>
</div>

<script>
const D=